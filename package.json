{
  "name": "nyx-css",
  "version": "1.0.2",
  "description": "A zero-dependency CSS & JS component framework with Luminous Depth — light & dark themes, fully themeable via CSS variables, with first-class RTL and Arabic typography.",
  "keywords": [
    "css",
    "ui",
    "components",
    "framework",
    "design-system",
    "dark-mode",
    "rtl",
    "arabic",
    "luminous-depth",
    "zero-dependencies"
  ],
  "homepage": "https://github.com/fadyehabamer/NYX#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fadyehabamer/NYX.git"
  },
  "bugs": {
    "url": "https://github.com/fadyehabamer/NYX/issues"
  },
  "license": "MIT",
  "author": "fadyehabamer",
  "main": "nyx.js",
  "style": "nyx.css",
  "unpkg": "nyx.min.css",
  "jsdelivr": "nyx.min.css",
  "sideEffects": [
    "*.css",
    "nyx.js",
    "nyx.min.js"
  ],
  "exports": {
    ".": "./nyx.js",
    "./css": "./nyx.css",
    "./css/min": "./nyx.min.css",
    "./js": "./nyx.js",
    "./js/min": "./nyx.min.js",
    "./components/*": "./components/*",
    "./package.json": "./package.json"
  },
  "files": [
    "nyx.css",
    "nyx.min.css",
    "nyx.js",
    "nyx.min.js",
    "components/",
    "fonts/",
    "build.js",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node build.js",
    "build:check": "node build.js && git diff --exit-code"
  }
}
